---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'KI-gestützte Nachrichtenanalyse-Plattform', ogImage } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | ouro.news</title>
  </head>
  <body class="min-h-screen bg-background text-text">
    <header class="sticky top-0 z-50 bg-surface border-b border-border shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-3">
            <span class="text-2xl font-bold text-primary">ouro.news</span>
          </a>
          <nav class="hidden md:flex items-center gap-6">
            <a href="/" class="text-sm font-medium hover:text-primary transition-colors">Startseite</a>
            <a href="/topics" class="text-sm font-medium hover:text-primary transition-colors">Themen</a>
            <a href="/countries" class="text-sm font-medium hover:text-primary transition-colors">Länder</a>
            <a href="/analysis" class="text-sm font-medium hover:text-primary transition-colors">Analyse</a>
            <a href="/patterns" class="text-sm font-medium hover:text-primary transition-colors">Muster</a>
          </nav>
          <div class="flex items-center gap-3">
            <slot name="header-actions" />
          </div>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-surface border-t border-border mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-sm text-text-muted">© {new Date().getFullYear()} ouro.news — KI-gestützte Nachrichtenanalyse</p>
          <nav class="flex gap-6">
            <a href="/admin" class="text-sm text-text-muted hover:text-primary transition-colors">Admin</a>
            <a href="/impressum" class="text-sm text-text-muted hover:text-primary transition-colors">Impressum</a>
            <a href="/datenschutz" class="text-sm text-text-muted hover:text-primary transition-colors">Datenschutz</a>
          </nav>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
