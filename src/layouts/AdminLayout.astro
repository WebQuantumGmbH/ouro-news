---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={`Admin: ${title}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-8">
      <nav class="space-y-1">
        <a href="/admin" class="block px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary/10 hover:text-primary transition-colors">
          Dashboard
        </a>
        <a href="/admin/sources" class="block px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary/10 hover:text-primary transition-colors">
          Quellen
        </a>
        <a href="/admin/settings" class="block px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary/10 hover:text-primary transition-colors">
          Einstellungen
        </a>
        <a href="/admin/users" class="block px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary/10 hover:text-primary transition-colors">
          Benutzer
        </a>
      </nav>
      <main>
        <h1 class="text-2xl font-bold mb-6">{title}</h1>
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>
